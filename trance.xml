<?xml version="1.0"?>
<Container version="2">
  <Name>trance</Name>
  <Repository>ghcr.io/studio2201/trance:latest</Repository>
  <Registry>https://ghcr.io/studio2201/trance</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/trance/issues</Support>
  <Project>https://github.com/studio2201/trance</Project>
  <Overview>High-performance audio streaming workstation and DJ web app built in Rust.</Overview>
  <Category>MediaApp:Music Network:Web</Category>
  <WebUI>http://[IP]:[PORT:4505]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/unraid-templates/main/templates/trance.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/unraid-templates/main/icons/trance.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>High-performance audio streaming workstation and DJ web app built in Rust.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>4505</HostPort>
        <ContainerPort>4505</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/trance</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>4505</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/config</Value>
      <Name>DATA_DIR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="4505" Default="4505" Mode="tcp" Description="HTTP Web Interface Port" Type="Port" Display="always" Required="true" Mask="false">4505</Config>
  <Config Name="App Storage Directory" Target="/config" Default="/mnt/user/appdata/trance" Mode="rw" Description="Persistent data and configuration directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/trance</Config>
</Container>
