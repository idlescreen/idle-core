#!/bin/sh
# postinst for trance (user-session daemon)
# Best-effort only: package configure must never fail on service restart.
set -u

# shellcheck source=../assets/packaging/user-service-lib.sh
# When packaged, this file is embedded; source sibling if present at build-time
# copy. Runtime ships lib next to scripts via inline — keep logic self-contained
# by sourcing from /usr if installed, else redefine minimal helpers below.

LIB=""
for candidate in \
    /usr/lib/idle/user-service-lib.sh \
    /usr/share/trance/user-service-lib.sh
do
    if [ -f "$candidate" ]; then
        LIB="$candidate"
        break
    fi
done

if [ -n "$LIB" ]; then
    # shellcheck disable=SC1090
    . "$LIB"
else
    # Inline fallback (package must still work if lib path missing).
    for_each_user_session() {
        _cb="$1"
        command -v loginctl >/dev/null 2>&1 || return 0
        command -v systemctl >/dev/null 2>&1 || return 0
        loginctl list-users --no-legend 2>/dev/null | while read -r uid user _rest; do
            case "$uid" in ''|*[!0-9]*) continue ;; esac
            [ -n "$user" ] || continue
            [ -d "/run/user/$uid" ] || continue
            [ -S "/run/user/$uid/bus" ] || continue
            "$_cb" "$uid" "$user" || true
        done
    }
    _user_systemctl() {
        _uid="$1"; _user="$2"; shift 2
        if command -v runuser >/dev/null 2>&1; then
            runuser -u "$_user" -- env \
                XDG_RUNTIME_DIR="/run/user/$_uid" \
                DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$_uid/bus" \
                systemctl --user "$@" 2>/dev/null && return 0
        fi
        systemctl --user --machine="${_user}@" "$@" 2>/dev/null || true
    }
    try_reload_user_units() {
        _user_systemctl "$1" "$2" daemon-reload || true
    }
    try_restart_trance() {
        _user_systemctl "$1" "$2" reset-failed idle-daemon.service || true
        # Enabled → always restart (try-restart is a no-op when inactive).
        if command -v runuser >/dev/null 2>&1; then
            if runuser -u "$2" -- env \
                XDG_RUNTIME_DIR="/run/user/$1" \
                DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$1/bus" \
                systemctl --user is-enabled idle-daemon.service >/dev/null 2>&1; then
                _user_systemctl "$1" "$2" restart idle-daemon.service || true
                return 0
            fi
        fi
        _user_systemctl "$1" "$2" try-restart idle-daemon.service || true
    }
    print_user_hint() {
        echo "  If needed: systemctl --user enable --now idle-daemon"
        echo "  or: trance doctor --fix"
    }
fi

case "${1:-}" in
    configure)
        echo "Configuring trance user service (best-effort)..."

        # Remove legacy XDG autostart (systemd user unit is the only start path).
        rm -f /etc/xdg/autostart/idle-daemon.desktop 2>/dev/null || true

        if command -v deb-systemd-helper >/dev/null 2>&1; then
            deb-systemd-helper --user unmask idle-daemon.service >/dev/null 2>&1 || true
            # Preset/enable helper state; per-user enable still recommended once.
            deb-systemd-helper --user enable idle-daemon.service >/dev/null 2>&1 || true
        fi

        for_each_user_session try_reload_user_units
        for_each_user_session try_restart_trance

        print_user_hint
        echo "trance package configure finished."
        ;;
esac

exit 0
