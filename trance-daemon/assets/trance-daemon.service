[Unit]
Description=Trance Screensaver Daemon
Documentation=https://github.com/local76/trance
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=dbus
BusName=com.local76.Trance
ExecStart=/usr/bin/trance-daemon daemon
Restart=on-failure
RestartSec=5
TimeoutStopSec=10
KillMode=mixed

# Security Hardening
NoNewPrivileges=true

[Install]
WantedBy=graphical-session.target
